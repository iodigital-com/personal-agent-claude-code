# Personal Agent Framework — optional overrides
# Copy to .env to change defaults.

# Anthropic API key — required to start Claude Code automatically
ANTHROPIC_AUTH_TOKEN=your-bonzai-api-key-here

# Container timezone — defaults to Europe/Amsterdam
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TZ=America/New_York
